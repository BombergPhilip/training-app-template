generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model exercise_order {
  id            Int             @id @default(autoincrement())
  program_id    Int
  exercise_id   Int
  order_nr      Int
  exercise_logs exercise_logs[]
}

model exercise_to_muscle {
  exercise_id   Int
  muscle_grp_id Int
  exercise      exercises     @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  muscle_groups muscle_groups @relation(fields: [muscle_grp_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([exercise_id, muscle_grp_id])
}

model muscle_groups {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(30)
  exercise_to_muscle exercise_to_muscle[]
}

model user_to_coach {
  user_id  Int     @id
  coach_id Int
  coaches  coaches @relation(fields: [coach_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  users    users   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(30)
  date_of_birth DateTime?      @db.Date
  weight_kg     Float?
  height_cm     Float?
  email         String         @db.VarChar(120)
  gender        gender_type?
  picture       String?        @db.VarChar(120)
  coaches       coaches?
  comments      comments[]
  passwords     passwords[]
  program_logs  program_logs[]
  templates     templates[]
  tokens        tokens[]
  user_to_coach user_to_coach?
}

model coaches {
  user_id       Int             @id
  price_dkk     Int
  max_clients   Int?            @default(20)
  users         users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_to_coach user_to_coach[]
}

model passwords {
  hash         String    @db.VarChar(256)
  user_id      Int
  last_updated DateTime? @default(now()) @db.Timestamp(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hash, user_id])
}

model program_logs {
  program_id Int
  user_id    Int
  date       DateTime @default(now()) @db.Timestamp(6)
  programs   programs @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([program_id, user_id, date])
}

model programs {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(30)
  date         DateTime?      @default(now()) @db.Timestamp(6)
  description  String         @db.VarChar(120)
  program_logs program_logs[]
  templates    templates?
}

model templates {
  program_id Int      @id
  user_id    Int
  programs   programs @relation(fields: [program_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model tokens {
  hash    String    @id @db.VarChar(256)
  user_id Int
  expires DateTime? @default(dbgenerated("(now() + '1 day'::interval)")) @db.Timestamp(6)
  users   users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model comments {
  id        Int     @id @default(autoincrement())
  owner     Int?
  attach_id Int?
  msg       String? @db.VarChar(256)
  users     users?  @relation(fields: [owner], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model exercise_logs {
  id                Int            @id @default(autoincrement())
  exercise_order_id Int
  reps              Int
  kg                Float
  exercise_order    exercise_order @relation(fields: [exercise_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model exercises {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(30)
  description        String               @db.VarChar(120)
  equipment          equipment_type
  exercise_to_muscle exercise_to_muscle[]
}

enum Equipment {
  None
  Barbell
  Dumbbell
  Kettlebell
  Machine
  Plate
  Resistance_Band
  Suspension_Band
  Other
}

enum Gender {
  male
  female
}

enum equipment_type {
  None
  Barbell
  Dumbbell
  Kettlebell
  Machine
  Plate
  Resistance_Band @map("Resistance Band")
  Suspension_Band @map("Suspension Band")
  Other
}

enum gender_type {
  male
  female
}
