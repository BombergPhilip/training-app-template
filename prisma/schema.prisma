generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(30)
  dateOfBirth DateTime  @db.Date
  weightKg    Float
  heightCm    Float
  email       String    @db.VarChar(120)
  gender      Gender
  picture     String?   @db.VarChar(120)

  @@map("user")
}

model Coach {
  userId     Int  @id
  priceDkk   Int?
  maxClients Int  @default(20)

  @@map("coach")
}

model UserToCoach {
  userId  Int @id
  coachId Int

  @@map("user_to_coach")
}

model Password {
  hash        String   @db.VarChar(256)
  ownerId     Int
  lastUpdated DateTime @default(now())

  @@id([hash, ownerId])
  @@map("password")
}

model Token {
  hash    String   @id @db.VarChar(256)
  owner   Int
  expires DateTime @default(dbgenerated("(now() + '1 day'::interval)")) @db.Timestamp(6)
  users   users    @relation(fields: [owner], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("token")
}

model Comment {
  id        Int     @id @default(autoincrement())
  owner     Int?
  attach_id Int?
  msg       String? @db.VarChar(256)
  users     users?  @relation(fields: [owner], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("comment")
}

model Program {
  id          Int      @id @default(autoincrement())
  name        String?  @db.VarChar(30)
  description String?  @db.VarChar(120)
  is_template Boolean? @default(false)

  @@map("program")
}

model ExerciseOrder {
  id           Int           @id @default(autoincrement())
  program_id   Int?
  exercise_id  Int?
  order_nr     Int?
  exercise_log ExerciseLog[]

  @@map("exercise_order")
}

model ExerciseLog {
  id                Int            @id @default(autoincrement())
  exercise_order_id Int?
  reps              Int?
  kg                Float?
  exercise_order    ExerciseOrder? @relation(fields: [exercise_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("exercise_log")
}

model Exercise {
  id                 Int                @id @default(autoincrement())
  name               String?            @db.VarChar(30)
  description        String?            @db.VarChar(120)
  equipment          equipment_type?
  exercise_to_muscle ExerciseToMuscle[]

  @@map("exercise")
}

model ExerciseToMuscle {
  exercise_id   Int
  muscle_grp_id Int
  exercise      Exercise     @relation(fields: [exercise_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  muscle_groups MuscleGroups @relation(fields: [muscle_grp_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([exercise_id, muscle_grp_id])
  @@map("exercise_to_muscle")
}

model MuscleGroups {
  id                 Int                @id @default(autoincrement())
  name               String?            @db.VarChar(30)
  exercise_to_muscle ExerciseToMuscle[]

  @@map("muscle_groups")
}

model users {
  id            Int          @id @default(autoincrement())
  name          String?      @db.VarChar(30)
  date_of_birth DateTime?    @db.Date
  weight_kg     Float?
  height_cm     Float?
  email         String?      @db.VarChar(120)
  gender        gender_type?
  picture       String?      @db.VarChar(120)
  comment       Comment[]
  token         Token[]
}

enum Gender {
  male
  female
}

enum Equipment {
  None
  Barbell
  Dumbbell
  Kettlebell
  Machine
  Plate
  Resistance_Band
  Suspension_Band
  Other
}

enum equipment_type {
  None
  Barbell
  Dumbbell
  Kettlebell
  Machine
  Plate
  Resistance_Band @map("Resistance Band")
  Suspension_Band @map("Suspension Band")
  Other
}

enum gender_type {
  male
  female
}
